{
	"name": "@hubble.md/desktop",
	"private": true,
	"version": "0.1.6",
	"description": "Desktop app for Hubble.md",
	"author": "Ben Holmes",
	"type": "module",
	"main": "./out/main/main.js",
	"scripts": {
		"dev": "node scripts/dev.mjs",
		"dev:debug": "HUBBLE_DESKTOP_ENABLE_CDP=1 node scripts/dev.mjs",
		"build": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit && electron-vite build",
		"bundle": "pnpm build && electron-builder --mac",
		"bundle:publish": "pnpm build && electron-builder --mac --publish always",
		"preview": "vite preview",
		"test": "vitest run"
	},
	"dependencies": {
		"@base-ui/react": "^1.3.0",
		"@floating-ui/dom": "^1.7.5",
		"@hubble.md/editor": "workspace:*",
		"@hubble.md/runtime": "workspace:*",
		"@hubble.md/ui": "workspace:*",
		"@simplestack/store": "^0.7.5",
		"@tailwindcss/browser": "^4.3.1",
		"@tiptap/core": "^3.4.3",
		"@tiptap/extension-image": "^3.4.2",
		"@tiptap/extension-list": "^3.4.2",
		"@tiptap/pm": "^3.3.0",
		"@tiptap/react": "^3.3.0",
		"@tiptap/starter-kit": "^3.3.0",
		"alpinejs": "^3.15.12",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"electron-updater": "^6.8.3",
		"ignore": "^7.0.5",
		"keymatch": "^1.0.5",
		"open-props": "^1.7.23",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"shadcn": "^4.1.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.5.0",
		"tw-animate-css": "^1.4.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@iconify-json/mingcute": "^1.2.7",
		"@svgr/core": "^8.1.0",
		"@svgr/plugin-jsx": "^8.1.0",
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^25.5.0",
		"@types/react": "^19.1.8",
		"@types/react-dom": "^19.1.6",
		"@vitejs/plugin-react": "^4.6.0",
		"chokidar": "^4.0.3",
		"electron": "^42.3.1",
		"electron-builder": "^26.8.1",
		"electron-vite": "^5.0.0",
		"tailwindcss": "^4.1.18",
		"typescript": "~5.8.3",
		"unplugin-icons": "^23.0.1",
		"vite": "^7.0.4",
		"vitest": "^3.2.4"
	},
	"build": {
		"appId": "com.benholmes.hubblemd.desktop",
		"productName": "Hubble",
		"directories": {
			"output": "release"
		},
		"icon": "assets/icon.icns",
		"files": [
			"out/**"
		],
		"publish": [
			{
				"provider": "github",
				"owner": "bholmesdev",
				"repo": "hubble.md",
				"tagNamePrefix": "desktop-v"
			}
		],
		"mac": {
			"target": [
				"dmg",
				"zip"
			],
			"category": "public.app-category.productivity"
		},
		"fileAssociations": [
			{
				"name": "Markdown Document",
				"description": "Markdown text file",
				"ext": [
					"md",
					"markdown",
					"mdown"
				],
				"role": "Editor",
				"rank": "Owner"
			}
		]
	}
}
