{
	"name": "hubble-md",
	"private": true,
	"version": "0.0.0",
	"scripts": {
		"check": "biome check .",
		"check:fix": "biome check . --write",
		"typecheck": "pnpm -r --if-present typecheck",
		"build": "pnpm check && pnpm -r --if-present build && pnpm typecheck",
		"build:desktop": "pnpm build",
		"bundle:desktop": "pnpm --filter @hubble.md/desktop... --if-present build && pnpm --filter @hubble.md/desktop bundle",
		"dev:desktop": "pnpm -r --parallel --stream --filter \"./packages/**\" --if-present dev & pnpm --filter \"./apps/desktop\" dev",
		"dev:desktop:debug": "pnpm -r --parallel --stream --filter \"./packages/**\" --if-present dev & pnpm --filter \"./apps/desktop\" dev:debug",
		"dev:www": "pnpm -r --parallel --stream --filter \"./packages/**\" --if-present dev & pnpm --filter \"./apps/www\" dev",
		"dev:sync-backend": "pnpm --filter \"./packages/sync-backend\" exec convex dev",
		"dev:cli": "pnpm --filter \"./packages/sync\" --filter \"./packages/cli\" --parallel --stream dev",
		"hubble": "node packages/cli/dist/index.js"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.4"
	}
}
