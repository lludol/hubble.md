{
	"name": "@hubble.md/ui",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./style.css": "./dist/index.css",
		"./tailwind.css": "./dist/tailwind.css",
		"./theme.css": "./dist/theme.css"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "vite build && tsc -p tsconfig.json --emitDeclarationOnly",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"dev": "vite build --watch"
	},
	"dependencies": {
		"@base-ui/react": "^1.3.0",
		"@floating-ui/dom": "^1.7.5",
		"@hubble.md/editor": "workspace:*",
		"@tiptap/core": "^3.4.3",
		"@tiptap/extension-list": "^3.4.2",
		"@tiptap/pm": "^3.3.0",
		"@tiptap/react": "^3.3.0",
		"@tiptap/starter-kit": "^3.3.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"keymatch": "^1.0.5",
		"tailwind-merge": "^3.5.0",
		"zod": "^4.4.3"
	},
	"peerDependencies": {
		"react": "^19.1.0",
		"react-dom": "^19.1.0"
	},
	"devDependencies": {
		"@iconify-json/mingcute": "^1.2.7",
		"@types/react": "^19.1.8",
		"typescript": "~5.8.3",
		"unplugin-icons": "^23.0.1",
		"vite": "^7.0.4"
	}
}
